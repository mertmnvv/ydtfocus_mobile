# ydtfocus-mobile ortam değişkenleri şablonu.
# Gerçek değerlerle .env dosyasına kopyala — .env asla commit edilmez.
#
# Bu değerler web reposundaki (ydtfocusv2) .env.local ile AYNI Firebase
# projesine işaret etmeli (bkz. PROJECT_STATUS.md — "Backend stratejisi").
# Expo'da runtime'da client'a expose edilen değişkenler EXPO_PUBLIC_
# önekiyle başlamalı.

# ── Firebase (web'deki NEXT_PUBLIC_FIREBASE_* ile birebir aynı proje) ──
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Google Sign-In (native) — android/app/google-services.json içindeki
# client_type: 3 (web client) OAuth client ID'si ──
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── AdMob (çark çevir — rewarded ad) ──
# Boş bırakılırsa src/lib/ads.ts Google'ın test reklam birimini kullanır.
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID=

# ── Web sitesinin domain'i ──
# Groq/Gemini/TTS/Wikipedia gibi sunucu-taraflı (API anahtarı gerektiren)
# tüm AI çağrıları ikinci bir backend yazılmadan, doğrudan web sitesinin
# mevcut /api/* route'ları üzerinden yapılır (bkz. PROJECT_STATUS.md).
EXPO_PUBLIC_API_BASE_URL=https://www.ydtfocus.xyz
